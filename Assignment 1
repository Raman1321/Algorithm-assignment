Task 1: Algorithm Growth Observation
​Implementation
​The following functions represent the four requested complexity classes:  

import time
import numpy as np
import matplotlib.pyplot as plt
import math

# 1. Constant Time: O(1)
def constant_algo(n):
    return 42 

# 2. Linear Time: O(n)
def linear_algo(n):
    count = 0
    for i in range(n):
        count += 1
    return count

# 3. Quadratic Time: O(n^2)
def quadratic_algo(n):
    count = 0
    for i in range(n):
        for j in range(n):
            count += 1
    return count

# 4. Logarithmic Time: O(log n)
def logarithmic_algo(n):
    count = 0
    while n > 1:
        n //= 2
        count += 1
    return count
Performance Measurement & Plotting
​We measure execution time for n = [10, 100, 500, 1000].  
sizes = [10, 100, 500, 1000]
results = { "O(1)": [], "O(n)": [], "O(n^2)": [], "O(log n)": [] }

for n in sizes:
    # O(1)
    start = time.perf_counter()
    constant_algo(n)
    results["O(1)"].append(time.perf_counter() - start)
    
    # O(n)
    start = time.perf_counter()
    linear_algo(n)
    results["O(n)"].append(time.perf_counter() - start)
    
    # O(n^2)
    start = time.perf_counter()
    quadratic_algo(n)
    results["O(n^2)"].append(time.perf_counter() - start)
    
    # O(log n)
    start = time.perf_counter()
    logarithmic_algo(n)
    results["O(log n)"].append(time.perf_counter() - start)

# Plotting
plt.figure(figsize=(10, 6))
for algo, times in results.items():
    plt.plot(sizes, times, label=algo, marker='o')
plt.xlabel('Input Size (n)')
plt.ylabel('Execution Time (seconds)')
plt.title('Algorithm Growth Observation')
plt.legend()
plt.grid(True)
