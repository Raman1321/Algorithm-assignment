def recurrence_1(n, count=0):
    if n <= 1: return count + 1
    # Work done is 'n', plus one recursive call on n/2
    return recurrence_1(n // 2, count + n)

def recurrence_2(n):
    if n <= 1: return 1
    # Two recursive calls on n/2, plus 'n' work
    return recurrence_2(n // 2) + recurrence_2(n // 2) + n
